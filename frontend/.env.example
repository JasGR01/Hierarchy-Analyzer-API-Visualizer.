# Frontend environment variables
# Copy this file to .env and fill in the deployed backend URL.
# NEVER commit the real .env file — it is listed in .gitignore.

# Local development (default)
VITE_API_URL=http://localhost:3001

# Production — replace with your actual deployed backend URL, e.g.:
# VITE_API_URL=https://bajaj-bfhl-api.onrender.com
